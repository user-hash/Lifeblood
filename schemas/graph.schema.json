{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph.schema.json",
  "title": "Lifeblood Semantic Graph",
  "description": "Language-agnostic semantic graph. Any language adapter can output this format. Lifeblood normalizes it and routes it to AI connectors. JSON uses camelCase; C# models use PascalCase. Capability fields have manual names (see CLAUDE.md Serialization Naming).",
  "type": "object",
  "required": ["version", "symbols", "edges"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "language": {
      "type": "string",
      "description": "Source language (e.g., csharp, python, typescript, go, rust, java)"
    },
    "adapter": {
      "type": "object",
      "description": "Adapter that produced this graph",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "capabilities": { "$ref": "#/$defs/capabilities" }
      }
    },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/$defs/module" }
    },
    "symbols": {
      "type": "array",
      "items": { "$ref": "#/$defs/symbol" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "symbol": {
      "type": "object",
      "required": ["id", "name", "kind"],
      "properties": {
        "id": { "type": "string", "description": "Globally unique within this graph" },
        "name": { "type": "string", "description": "Short display name" },
        "qualifiedName": { "type": "string", "description": "Fully qualified name" },
        "kind": { "type": "string", "enum": ["module", "file", "namespace", "type", "method", "field", "parameter"] },
        "filePath": { "type": "string", "description": "Source file path (relative)" },
        "line": { "type": "integer", "minimum": 0, "description": "Line number (1-based)" },
        "parentId": { "type": "string", "description": "Parent symbol ID in containment hierarchy" },
        "visibility": { "type": "string", "enum": ["public", "internal", "protected", "private"] },
        "isAbstract": { "type": "boolean" },
        "isStatic": { "type": "boolean" },
        "properties": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Language-specific metadata"
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["sourceId", "targetId", "kind"],
      "properties": {
        "sourceId": { "type": "string" },
        "targetId": { "type": "string" },
        "kind": { "type": "string", "enum": ["contains", "dependsOn", "implements", "inherits", "calls", "references", "overrides"] },
        "evidence": { "$ref": "#/$defs/evidence" },
        "properties": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "module": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "filePaths": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "isPure": { "type": "boolean" },
        "isTooling": { "type": "boolean" },
        "properties": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "enum": ["syntax", "semantic", "inferred"] },
        "adapterName": { "type": "string" },
        "sourceSpan": { "type": "string", "description": "e.g., src/Auth.cs:47" },
        "confidence": { "type": "string", "enum": ["none", "bestEffort", "high", "proven"] }
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "discoverSymbols": { "type": "boolean" },
        "typeResolution": { "type": "string", "enum": ["none", "bestEffort", "high", "proven"] },
        "callResolution": { "type": "string", "enum": ["none", "bestEffort", "high", "proven"] },
        "implementationResolution": { "type": "string", "enum": ["none", "bestEffort", "high", "proven"] },
        "crossModuleReferences": { "type": "string", "enum": ["none", "bestEffort", "high", "proven"] },
        "overrideResolution": { "type": "string", "enum": ["none", "bestEffort", "high", "proven"] },
      }
    }
  }
}
