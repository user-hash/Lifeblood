{
  "name": "Hexagonal Architecture",
  "description": "Ports & Adapters. Domain is pure, infrastructure implements ports.",
  "version": "1.0",
  "rules": [
    {
      "id": "HEX-001",
      "description": "Domain must not reference Infrastructure",
      "source": "*.Domain",
      "mustNotReference": "*.Infrastructure"
    },
    {
      "id": "HEX-002",
      "description": "Domain must not reference Adapters",
      "source": "*.Domain",
      "mustNotReference": "*.Adapters"
    },
    {
      "id": "HEX-003",
      "description": "Domain must not reference Presentation",
      "source": "*.Domain",
      "mustNotReference": "*.Presentation"
    },
    {
      "id": "HEX-004",
      "description": "App layer must not reference Infrastructure directly",
      "source": "*.App",
      "mustNotReference": "*.Infrastructure"
    },
    {
      "id": "HEX-005",
      "description": "Domain must not reference platform/engine types",
      "source": "*.Domain",
      "mustNotReference": "UnityEngine"
    },
    {
      "id": "HEX-006",
      "description": "Domain must not reference platform/engine types",
      "source": "*.Domain",
      "mustNotReference": "System.Net.*"
    }
  ]
}
