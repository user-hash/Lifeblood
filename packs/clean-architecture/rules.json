{
  "name": "Clean Architecture",
  "description": "Dependency rule: inner layers must not reference outer layers.",
  "version": "1.0",
  "rules": [
    {
      "id": "CLEAN-001",
      "description": "Entities must not reference Use Cases",
      "source": "*.Entities",
      "mustNotReference": "*.UseCases"
    },
    {
      "id": "CLEAN-002",
      "description": "Entities must not reference Interface Adapters",
      "source": "*.Entities",
      "mustNotReference": "*.Adapters"
    },
    {
      "id": "CLEAN-003",
      "description": "Entities must not reference Frameworks",
      "source": "*.Entities",
      "mustNotReference": "*.Frameworks"
    },
    {
      "id": "CLEAN-004",
      "description": "Use Cases must not reference Interface Adapters",
      "source": "*.UseCases",
      "mustNotReference": "*.Adapters"
    },
    {
      "id": "CLEAN-005",
      "description": "Use Cases must not reference Frameworks",
      "source": "*.UseCases",
      "mustNotReference": "*.Frameworks"
    }
  ]
}
